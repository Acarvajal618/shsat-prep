    "diagram": null,
    "solution": {
      "strategy": "After evaporation sand=4, water=16−w. Set 4/(16−w)=2/3, solve for w.",
      "steps": [
        "4/(16−w) = 2/3 → 12 = 32−2w",
        "2w = 20 → w = 10"
      ],
      "final_answer": "10"
    }
